		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"better-sqlite3": "^12.11.1",
		"koffi": "^3.1.1",
